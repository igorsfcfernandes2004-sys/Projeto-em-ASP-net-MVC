@model MeuProjetoMVC.Models.Endereco

<h2>Consulta CEP</h2>

<form asp-action="Cadastro" method="post">

    <div>
        <label>Nome</label>
        <input asp-for="Nome" />
    </div>

    <div>
        <label>CEP</label>
        <input asp-for="Cep" id="cep" />
    </div>

    <div>
        <label>Número</label>
        <input asp-for="Numero" />
    </div>

    <div>
        <label>Logradouro</label>
        <input asp-for="Logradouro" id="logradouro" />
    </div>

    <div>
        <label>Bairro</label>
        <input asp-for="Bairro" id="bairro" />
    </div>

    <div>
        <label>Cidade</label>
        <input asp-for="Cidade" id="cidade" />
    </div>

    <div>
        <label>UF</label>
        <input asp-for="UF" id="uf" />
    </div>

    <button type="submit">Enviar</button>

</form>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<script>
$("#cep").blur(function () {

    var cep = $(this).val().replace(/\D/g, '');

    $.getJSON("https://viacep.com.br/ws/" + cep + "/json/", function (dados) {

        $("#logradouro").val(dados.logradouro);
        $("#bairro").val(dados.bairro);
        $("#cidade").val(dados.localidade);
        $("#uf").val(dados.uf);

    });

});
</script>