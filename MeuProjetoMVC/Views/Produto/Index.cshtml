@{
    ViewData["Title"] = "Catálogo de Produtos";

    List<string> produtos = ViewBag.Produtos;
    List<double> precos = ViewBag.Precos;
}

<h1>Catálogo de Produtos</h1>

<table border="1">
    <tr>
        <th>#</th>
        <th>Nome</th>
        <th>Preço</th>
    </tr>

    @for (int i = 0; i < produtos.Count; i++)
    {
        <tr style="color:@(precos[i] < 100 ? "green" : "black")">
            <td>@(i + 1)</td>
            <td>@produtos[i]</td>
            <td>R$ @precos[i]</td>
        </tr>
    }
</table>

<h3>Total: @produtos.Count produtos</h3>