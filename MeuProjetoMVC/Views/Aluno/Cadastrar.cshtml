@model MeuProjetoMVC.Models.Aluno

<h1>Cadastro de Aluno</h1>

<form asp-action="Cadastrar" method="post">

    <div>
        <label asp-for="Nome"></label>
        <input asp-for="Nome" />
        <span asp-validation-for="Nome" style="color:red"></span>
    </div>

    <div>
        <label asp-for="Email"></label>
        <input asp-for="Email" />
        <span asp-validation-for="Email" style="color:red"></span>
    </div>

    <div>
        <label asp-for="RA"></label>
        <input asp-for="RA" />
        <span asp-validation-for="RA" style="color:red"></span>
    </div>

    <div>
        <label asp-for="Curso"></label>
        <input asp-for="Curso" />
        <span asp-validation-for="Curso" style="color:red"></span>
    </div>

    <div>
        <label asp-for="DataNascimento"></label>
        <input asp-for="DataNascimento" type="date" />
        <span asp-validation-for="DataNascimento" style="color:red"></span>
    </div>

    <br />

    <button type="submit">Cadastrar</button>

</form>